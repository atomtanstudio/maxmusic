# Copy to .env for local development — never commit .env
# Get a key: https://platform.minimax.io/

# Optional: server-side key (omit on public hosts — users supply keys in Settings)
# MINIMAX_API_KEY=

PORT=3001
NODE_ENV=development

# Comma-separated origins allowed to call the API in production (e.g. https://maxmusic.onrender.com)
# ALLOWED_ORIGINS=